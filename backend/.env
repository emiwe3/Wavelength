SECRET_KEY=change-me-to-a-random-string
APP_BASE_URL=http://localhost:8000

# Google OAuth — console.cloud.google.com
# Enable: Google Calendar API, Gmail API
# Authorized redirect URI: http://localhost:8000/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Slack OAuth — api.slack.com/apps
# Redirect URL: http://localhost:8000/auth/slack/callback
# User Token Scopes: channels:history, im:history, channels:read, im:read
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=

# Canvas OAuth (optional — only if your school issued a developer key)
# Most users should use the token paste UI instead
CANVAS_CLIENT_ID=
CANVAS_CLIENT_SECRET=
