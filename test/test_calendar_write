"""
test/test_calendar_write — tests calendar write + conflict detection.

Simulates a student adding events via natural language, including cases
where the new event conflicts with an existing one.

Run from the project root:
    python3.13 test/test_calendar_write
"""

import json
import os
import sys

sys.path.insert(0, os.path.join(os.path.dirname(__file__), "..", "backend"))

from dotenv import load_dotenv
load_dotenv(os.path.join(os.path.dirname(__file__), "..", "backend", ".env"))

TOKEN_FILE = os.path.join(os.path.dirname(__file__), "..", "google", "seed_token.json")

if not os.path.exists(TOKEN_FILE):
    print("ERROR: google/seed_token.json not found. Run: cd google && python3.13 seed_data.py")
    sys.exit(1)

with open(TOKEN_FILE) as f:
    gmail_creds = json.load(f)

user = {
    "phone": "+10000000000",
    "ical_url": os.getenv("GOOGLE_ICAL_URL"),
    "gmail_credentials": gmail_creds,
    "canvas_token": os.getenv("CANVAS_API_TOKEN"),
    "canvas_domain": "canvas.harvard.edu",
    "slack_token": os.getenv("SLACK_BOT_TOKEN"),
    "slack_channel": os.getenv("SLACK_CHANNEL_ID"),
}

import agent

conversations = [
    # ── No conflict — should create immediately ──────────────────────────
    [
        "add gym session tomorrow at 7am",
    ],
    # ── No conflict, no end time — should default to 1 hour ─────────────
    [
        "block off Sunday night 8pm for studying",
    ],
    # ── Conflict — Tuesday 1pm conflicts with CS 301 Section ─────────────
    # Expected: Claude warns about the conflict, asks to confirm
    # Then student says yes, Claude creates it
    [
        "add a coffee chat Tuesday at 1pm",
        "yes go ahead and add it",
    ],
    # ── Conflict — Thursday 3pm conflicts with MATH 260 quiz ─────────────
    # Expected: Claude warns, student declines
    [
        "schedule a study session Thursday at 3pm",
        "actually skip it, ill find another time",
    ],
    # ── Multi-detail event ───────────────────────────────────────────────
    [
        "add team project meeting next monday 2pm to 4pm",
    ],
]

print("=" * 60)
print("Calendar Write + Conflict Detection Test")
print("=" * 60)

for i, convo in enumerate(conversations, 1):
    print(f"\n--- Conversation {i} ---")
    agent.clear_history(user["phone"])
    for msg in convo:
        print(f"\nYou: {msg}")
        print(f"\nPulsePoint: {agent.reply(user, msg)}")
    print()
