#!/usr/bin/env python3.13
"""
Test image → calendar parsing.
Usage: python3.13 test/test_image path/to/syllabus.jpg

Calls parse_image() directly against your real user account.
Will actually add events to your Google Calendar.
"""

import sys
import os
import base64

sys.path.insert(0, os.path.join(os.path.dirname(__file__), "../backend"))
from dotenv import load_dotenv
load_dotenv(os.path.join(os.path.dirname(__file__), "../backend/.env"))

import db
import agent

if len(sys.argv) < 2:
    print("Usage: python3.13 test/test_image path/to/image.jpg")
    sys.exit(1)

image_path = sys.argv[1]
if not os.path.exists(image_path):
    print(f"File not found: {image_path}")
    sys.exit(1)

# Detect media type from extension
ext = os.path.splitext(image_path)[1].lower()
media_types = {".jpg": "image/jpeg", ".jpeg": "image/jpeg", ".png": "image/png", ".heic": "image/heic"}
media_type = media_types.get(ext, "image/jpeg")

with open(image_path, "rb") as f:
    image_base64 = base64.standard_b64encode(f.read()).decode()

# Use the first user in the DB (your account)
users = db.get_all_users()
if not users:
    print("No users in DB. Register first via the frontend.")
    sys.exit(1)

user = users[0]
print(f"Using account: {user['phone']}")
print(f"Google connected: {bool(user.get('gmail_credentials'))}")
print(f"Image: {image_path} ({media_type})\n")
print("Sending to Claude...\n")

result = agent.parse_image(user, image_base64, media_type)
print(result)
