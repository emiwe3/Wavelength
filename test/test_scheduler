#!/usr/bin/env python3.13
"""
Test the proactive scheduler logic without waiting for cron.
Injects a fake deadline at 0.5h, 20h, and 60h from now and runs the check.
Prints what message would be sent — does NOT actually send iMessages.
"""

import sys, os
from datetime import datetime, timedelta, timezone
from unittest.mock import patch

sys.path.insert(0, os.path.join(os.path.dirname(__file__), "../backend"))
from dotenv import load_dotenv
load_dotenv(os.path.join(os.path.dirname(__file__), "../backend/.env"))

import scheduler
import agent

# Fake user — no real credentials needed for this test
FAKE_USER = {
    "phone": "+16175550000",
    "canvas_token": None,
    "canvas_domain": None,
    "ical_url": None,
    "gmail_credentials": None,
    "slack_token": None,
    "reminders_sent": {},
}

now = datetime.now(timezone.utc)

FAKE_DEADLINES = [
    ("hw_1", "CS50 Problem Set 5",  now + timedelta(hours=0.5)),   # → 1h alert
    ("hw_2", "Econ 101 Essay",      now + timedelta(hours=20)),    # → 24h alert
    ("hw_3", "Chemistry Lab Report", now + timedelta(hours=60)),   # → 72h alert
    ("hw_4", "History Paper",        now + timedelta(hours=80)),   # → no alert yet
]

sent_messages = []

def fake_send(phone, text):
    sent_messages.append((phone, text))

def fake_proactive(user, prompt):
    # Call the real Claude agent so you see actual message quality
    return agent.proactive_message(user, prompt)

print("Running deadline check with fake deadlines...\n")

with patch("scheduler._collect_deadlines", return_value=FAKE_DEADLINES), \
     patch("messenger.send_message", side_effect=fake_send), \
     patch("db.upsert_user"):
    scheduler._check_user(FAKE_USER)

print(f"Messages sent: {len(sent_messages)}\n")
for i, (phone, text) in enumerate(sent_messages, 1):
    print(f"--- Message {i} ---")
    print(text)
    print()

if len(sent_messages) != 3:
    print(f"WARNING: expected 3 messages (1h, 24h, 72h), got {len(sent_messages)}")
else:
    print("All 3 reminder windows triggered correctly.")
