"""
test/test_slack — smoke test for the Slack pipeline.

Run from the project root:
    python3.13 test/test_slack
"""

import os
import sys

sys.path.insert(0, os.path.join(os.path.dirname(__file__), "..", "backend"))

from dotenv import load_dotenv
load_dotenv(os.path.join(os.path.dirname(__file__), "..", "backend", ".env"))

import slack_sync

token = os.getenv("SLACK_BOT_TOKEN")
channel_ids = os.getenv("SLACK_CHANNEL_ID")

if not token or not channel_ids:
    print("ERROR: SLACK_BOT_TOKEN or SLACK_CHANNEL_ID not set in backend/.env")
    sys.exit(1)

print(f"Reading from channels: {channel_ids}\n")

messages = slack_sync.get_announcements(token, channel_ids)

print(f"{len(messages)} messages found\n")
print("=" * 60)
for m in messages:
    print(f"[#{m['channel']}] {m['text'][:200]}")
    print("-" * 60)
